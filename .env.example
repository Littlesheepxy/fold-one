# ── Fold Runtime ───────────────────────────────────────────────

# ASR（阿里云百炼）
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=fun-asr-realtime
DASHSCOPE_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
ASR_PROXY_PORT=3003
FOLD_ASR_WS_URL=ws://localhost:3003

# Planner
FOLD_PLANNER_PROVIDER=openrouter
FOLD_PLANNER_MODEL=openai/gpt-5.5
OPENROUTER_API_KEY=

# OCR fallback for scanned PDFs/images
ZHIPU_API_KEY=
ZHIPU_OCR_MODEL=glm-ocr

# 其他 Provider（改 FOLD_PLANNER_PROVIDER 时启用）
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=

# Desktop
FOLD_DATA_DIR=~/.fold
FOLD_MAIL_PROVIDER=auto
# FOLD_CHROME_CDP_URL=http://127.0.0.1:9222
FOLD_ALLOW_SCRIPT_EXECUTION=0
FOLD_ALLOW_FILE_WRITE=0
