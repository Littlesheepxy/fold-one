# ── Fold Runtime ───────────────────────────────────────────────

# ASR（阿里云百炼 → PC / asr-proxy）
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=qwen3.5-omni-flash-realtime
DASHSCOPE_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_OMNI_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ASR_PROXY_PORT=3003
# ASR_PROXY_REQUIRE_AUTH=1
# ASR_PROXY_SKIP_AUTH=1
FOLD_ASR_WS_URL=ws://localhost:3003
FOLD_HUB_URL=https://foldhub.cn
# auto | local-funasr | local-whisper | dashscope
FOLD_ASR_PROVIDER=auto
FOLD_LOCAL_WHISPER_MODEL_PATH=~/.fold/models/ggml-small.bin

# iOS 豆包 ASR（火山 SpeechEngineAsrToB → account-api GET /asr/volc-token）
# 控制台：火山引擎 → 语音技术 → 流式语音识别；cluster 常用 volcengine_streaming_common
VOLC_ASR_APP_ID=
VOLC_ASR_TOKEN=
VOLC_ASR_CLUSTER=volcengine_streaming_common

# Planner（Agent 任务规划，偏质量）
# Kimi Code Plan（推荐国内）：provider=moonshot + model=k3 + Code Plan base
FOLD_PLANNER_PROVIDER=moonshot
FOLD_PLANNER_MODEL=k3
MOONSHOT_BASE_URL=https://api.kimi.com/coding/v1
MOONSHOT_API_KEY=
# 备选 OpenRouter：FOLD_PLANNER_PROVIDER=openrouter / FOLD_PLANNER_MODEL=deepseek/deepseek-chat

# Fast LLM（转写净化、代回草案文本路径，偏速度）
FOLD_FAST_PROVIDER=openrouter
FOLD_FAST_MODEL=google/gemini-3.1-flash-lite
# 仅配 DashScope 时可改为：FOLD_FAST_PROVIDER=dashscope / FOLD_FAST_MODEL=qwen-flash

# 代回多模态（截图直出草案；默认智谱 glm-5v-turbo，关 thinking）
# 有 ZHIPU_API_KEY 时自动走视觉；失败再回退 OCR+Fast 文本
# FOLD_VISION_PROVIDER=zhipu
# FOLD_VISION_MODEL=glm-5v-turbo
# 备选：FOLD_VISION_PROVIDER=dashscope / FOLD_VISION_MODEL=qwen3-vl-flash

OPENROUTER_API_KEY=

# 智谱（代回 VL 默认 + OCR 回退）
ZHIPU_API_KEY=
ZHIPU_OCR_MODEL=glm-ocr

# 其他 Provider（改 FOLD_PLANNER_PROVIDER 时启用）
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=   # Code Plan 密钥见上方 Planner 段

# Desktop
FOLD_DATA_DIR=~/.fold
# Context 额外监听目录（冒号分隔，如 ~/Projects/my-app:~/work）
# FOLD_WATCH_DIRS=~/Projects:~/work
# free | pro | ultra
FOLD_PLAN_TIER=free
FOLD_MAIL_PROVIDER=auto
# FOLD_CHROME_CDP_URL=http://127.0.0.1:9222
FOLD_ALLOW_SCRIPT_EXECUTION=0
FOLD_ALLOW_FILE_WRITE=0
