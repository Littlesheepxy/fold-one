    { "id": "utt_008", "category": "普通口语", "text": "我先把这个想法记下来，等会儿再展开", "wavFile": "utt_008.wav", "notes": null },
    { "id": "utt_009", "category": "普通口语", "text": "这个版本先不要发出去，我还想再改两处", "wavFile": "utt_009.wav", "notes": null },
    { "id": "utt_010", "category": "普通口语", "text": "你帮我把刚才那段话整理成更正式的语气", "wavFile": "utt_010.wav", "notes": null },
    { "id": "utt_011", "category": "带停顿", "text": "我想一下……这个结论可能不能这么写", "wavFile": "utt_011.wav", "notes": null },
    { "id": "utt_012", "category": "带停顿", "text": "等一下，我先确认一下数字，再继续说", "wavFile": "utt_012.wav", "notes": null },
    { "id": "utt_013", "category": "自我修正", "text": "把预算写成两百万，不对，是两百五十万", "wavFile": "utt_013.wav", "notes": null },
    { "id": "utt_014", "category": "自我修正", "text": "周五上午十点发给他，算了，改成下午两点", "wavFile": "utt_014.wav", "notes": null },
    { "id": "utt_015", "category": "中英文混输", "text": "这个 issue 里面的 reproduction steps 写得不够清楚", "wavFile": "utt_015.wav", "notes": null },
    { "id": "utt_016", "category": "中英文混输", "text": "帮我 compare 一下这两个 branch 的 diff", "wavFile": "utt_016.wav", "notes": null },
    { "id": "utt_017", "category": "产品术语", "text": "Fast Path 要优先保证 first character latency", "wavFile": "utt_017.wav", "notes": null },
    { "id": "utt_018", "category": "产品术语", "text": "这个 resolver 不应该每次重置整段 transcript", "wavFile": "utt_018.wav", "notes": null },
    { "id": "utt_019", "category": "Agent 指令", "text": "帮我查一下今天上午的会议纪要里面有没有提到预算", "wavFile": "utt_019.wav", "notes": null },
    { "id": "utt_020", "category": "Agent 指令", "text": "把这段内容改成发给投资人的版本，语气直接一点", "wavFile": "utt_020.wav", "notes": null },
    { "id": "utt_021", "category": "投资业务", "text": "这家公司今年 ARR 大概三千万，续费率还可以", "wavFile": "utt_021.wav", "notes": null },
    { "id": "utt_022", "category": "投资业务", "text": "我们需要确认一下毛利率和销售回款周期", "wavFile": "utt_022.wav", "notes": null },
    { "id": "utt_023", "category": "数字", "text": "把金额写成一千二百三十六万人民币", "wavFile": "utt_023.wav", "notes": null },
    { "id": "utt_024", "category": "数字", "text": "这个模型 P95 延迟不能超过八百毫秒", "wavFile": "utt_024.wav", "notes": null },
    { "id": "utt_025", "category": "噪声口语", "text": "嗯这个地方先留着，后面我再补一个例子", "wavFile": "utt_025.wav", "notes": null },
    { "id": "utt_026", "category": "噪声口语", "text": "其实吧，我觉得用户真正关心的是输入有没有打断思路", "wavFile": "utt_026.wav", "notes": null },
    { "id": "utt_027", "category": "长语音", "text": "我想把这个输入体验拆成两个阶段，第一阶段是用户刚开始说话的时候系统必须马上给反馈，哪怕文本还不完全准确；第二阶段是用户说完之后再用更重的模型做一次修正，这样既能保持速度，也能保证最后进入上下文的内容足够可靠。", "wavFile": "utt_027.wav", "notes": "30-60 seconds natural delivery" },
    { "id": "utt_028", "category": "长语音", "text": "今天的重点不是比较哪个模型理论上更强，而是看它放在真实输入链路里会不会让人觉得卡。我们要看第一个字出现得多快，中间字幕是不是稳定，以及修改已经显示文本的频率有多高。", "wavFile": "utt_028.wav", "notes": "30-60 seconds natural delivery" },
    { "id": "utt_029", "category": "长语音", "text": "如果一个模型最终准确率不错，但是每次都要等一句话结束才显示结果，那它就不适合作为 Fold 的 Fast Path。相反，如果它能很快吐出可用的 partial，后面再交给 Final Path 修正，这个组合可能更符合产品体验。", "wavFile": "utt_029.wav", "notes": "30-60 seconds natural delivery" },
    { "id": "utt_030", "category": "长语音", "text": "我们在报告里不要直接根据网上 benchmark 做结论，要用同一批本机录音，在同一台 Apple Silicon Mac 上跑完整链路，包括音频转换、识别、partial resolver 和最终报告输出。", "wavFile": "utt_030.wav", "notes": "30-60 seconds natural delivery" }
  ]
}
